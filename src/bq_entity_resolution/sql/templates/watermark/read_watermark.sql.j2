{#
  Read current watermark values for a source.

  Parameters:
    table: fully-qualified watermark table name
    source_name: source identifier
#}

SELECT
  cursor_column,
  cursor_value,
  cursor_type,
  updated_at
FROM `{{ table }}`
WHERE source_name = '{{ source_name | sql_escape }}'
  AND is_current = TRUE
ORDER BY cursor_column

{#
  Generate all engineered features from staged source data.

  Supports single or multiple source tables. Multiple sources are
  UNION ALL'd together before feature computation.

  Parameters:
    target_table: fully-qualified output table
    source_tables: list of fully-qualified staged input tables
    feature_expressions: list of {name, expression} (independent features)
    dependent_features: list of {name, expression} (features depending on pass 1)
    blocking_keys: list of {name, expression}
    composite_keys: list of {name, expression}
    source_columns: list of column names to carry through
    passthrough_columns: list of passthrough column names
    custom_joins: list of {table, alias, on} for custom feature joins
#}

CREATE OR REPLACE TABLE `{{ target_table }}`
{% if cluster_by %}
CLUSTER BY {{ cluster_by | join(', ') }}
{% endif %}
AS

WITH base AS (
  {% for src_table in source_tables %}
  SELECT
    entity_uid,
    source_name,
    _source_updated_at,
    _pipeline_loaded_at,
    {% for col in source_columns %}
    {{ col }},
    {% endfor %}
    {% for col in passthrough_columns %}
    {{ col }}{{ "," if not loop.last or feature_expressions }}
    {% endfor %}
  FROM `{{ src_table }}`
  {{ "UNION ALL" if not loop.last else "" }}
  {% endfor %}
),

{# Pass 1: Independent features from source columns #}
features_pass1 AS (
  SELECT
    b.*,
    {% for feat in feature_expressions %}
    {{ feat.expression }} AS {{ feat.name }}{{ "," if not loop.last }}
    {% endfor %}
  FROM base b
  {% for join in custom_joins %}
  LEFT JOIN `{{ join.table }}` AS {{ join.alias }}
    ON {{ join.on }}
  {% endfor %}
),

{# Pass 2: Dependent features (may reference Pass 1 feature columns) #}
featured AS (
  SELECT
    p.*{{ "," if dependent_features is defined and dependent_features }}
    {% if dependent_features is defined and dependent_features %}
    {% for feat in dependent_features %}
    {{ feat.expression }} AS {{ feat.name }}{{ "," if not loop.last }}
    {% endfor %}
    {% endif %}
  FROM features_pass1 p
)

{# Pass 3: Blocking keys and composite keys (may depend on any feature) #}
SELECT
  f.*,

  {# Blocking keys #}
  {% for bk in blocking_keys %}
  {{ bk.expression }} AS {{ bk.name }},
  {% endfor %}

  {# Composite keys #}
  {% for ck in composite_keys %}
  {{ ck.expression }} AS {{ ck.name }}{{ "," if not loop.last }}
  {% endfor %}

FROM featured f

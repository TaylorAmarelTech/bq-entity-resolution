{#
  Compute text embeddings using BigQuery ML remote model.

  Parameters:
    target_table: fully-qualified output table
    source_table: fully-qualified featured input table
    concat_expression: SQL expression for text to embed
    model_name: ML model name or endpoint
    dimensions: embedding dimensions
#}

CREATE OR REPLACE TABLE `{{ target_table }}` AS

WITH texts AS (
  SELECT
    entity_uid,
    {{ concat_expression }} AS text_to_embed
  FROM `{{ source_table }}`
  WHERE {{ concat_expression }} IS NOT NULL
    AND CHAR_LENGTH(TRIM({{ concat_expression }})) > 0
)

SELECT
  t.entity_uid,
  t.text_to_embed,
  result.text_embedding AS embedding
FROM
  ML.GENERATE_TEXT_EMBEDDING(
    MODEL `{{ model_name }}`,
    (SELECT * FROM texts),
    STRUCT(TRUE AS flatten_json_output, {{ dimensions }} AS output_dimensionality)
  ) AS result
JOIN texts t ON t.entity_uid = result.entity_uid

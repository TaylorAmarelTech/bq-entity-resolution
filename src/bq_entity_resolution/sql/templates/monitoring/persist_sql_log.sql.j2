{#
  Persist the pipeline SQL audit trail to BigQuery.

  Parameters:
    audit_table: fully-qualified audit table name
    run_id: pipeline run identifier
    entries: list of {stage, step, sql, timestamp}
#}

-- Ensure audit table exists
CREATE TABLE IF NOT EXISTS `{{ audit_table }}` (
  run_id STRING,
  stage STRING,
  step STRING,
  sql_text STRING,
  executed_at STRING
);

-- Insert audit entries
{% if entries %}
INSERT INTO `{{ audit_table }}`
  (run_id, stage, step, sql_text, executed_at)
VALUES
{% for entry in entries %}
  (
    '{{ run_id | sql_escape }}',
    '{{ entry.stage | sql_escape }}',
    '{{ entry.step | sql_escape }}',
    '{{ entry.sql | sql_escape }}',
    '{{ entry.timestamp | sql_escape }}'
  ){{ "," if not loop.last }}
{% endfor %};
{% endif %}

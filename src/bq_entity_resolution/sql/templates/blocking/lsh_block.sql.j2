{#
  Compute LSH bucket assignments from embeddings using random hyperplane LSH.

  Uses BigQuery scripting to generate random projections and compute
  sign-based hash buckets for each hash table.

  Parameters:
    target_table: fully-qualified output table
    embedding_table: fully-qualified table with entity_uid + embedding columns
    num_tables: number of LSH hash tables
    num_functions: number of hash functions per table
    dimensions: embedding dimensionality
    seed: random seed for reproducible projections
    bucket_prefix: column name prefix for bucket columns
#}

DECLARE dim INT64 DEFAULT {{ dimensions }};

CREATE OR REPLACE TABLE `{{ target_table }}` AS

WITH embeddings AS (
  SELECT
    entity_uid,
    embedding
  FROM `{{ embedding_table }}`
  WHERE embedding IS NOT NULL
    AND ARRAY_LENGTH(embedding) = dim
),

{# Generate random projection vectors using a seeded approach #}
projections AS (
  SELECT
    table_id,
    func_id,
    dim_idx,
    -- Deterministic pseudo-random: hash(seed, table, func, dim)
    (FARM_FINGERPRINT(
      CONCAT(
        CAST({{ seed }} AS STRING), '|',
        CAST(table_id AS STRING), '|',
        CAST(func_id AS STRING), '|',
        CAST(dim_idx AS STRING)
      )
    ) / 9223372036854775807.0) AS projection_value
  FROM
    UNNEST(GENERATE_ARRAY(0, {{ num_tables - 1 }})) AS table_id,
    UNNEST(GENERATE_ARRAY(0, {{ num_functions - 1 }})) AS func_id,
    UNNEST(GENERATE_ARRAY(0, dim - 1)) AS dim_idx
),

{# Compute dot products: sign(embedding . projection) for each hash function #}
dot_products AS (
  SELECT
    e.entity_uid,
    p.table_id,
    p.func_id,
    SUM(e.embedding[OFFSET(p.dim_idx)] * p.projection_value) AS dot_product
  FROM embeddings e
  CROSS JOIN projections p
  GROUP BY e.entity_uid, p.table_id, p.func_id
),

{# Build hash signature per table: concatenate signs #}
signatures AS (
  SELECT
    entity_uid,
    table_id,
    FARM_FINGERPRINT(
      STRING_AGG(
        CAST(IF(dot_product >= 0, 1, 0) AS STRING),
        ''
        ORDER BY func_id
      )
    ) AS bucket_hash
  FROM dot_products
  GROUP BY entity_uid, table_id
)

{# Pivot to one column per hash table #}
SELECT
  entity_uid,
  {% for i in range(num_tables) %}
  MAX(IF(table_id = {{ i }}, bucket_hash, NULL)) AS {{ bucket_prefix }}_{{ i }}{{ "," if not loop.last }}
  {% endfor %}
FROM signatures
GROUP BY entity_uid

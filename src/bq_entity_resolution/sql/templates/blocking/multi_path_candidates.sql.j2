{#
  Multi-path blocking: generate candidate pairs from multiple blocking paths,
  with per-path candidate limits, deduplication, and prior-match exclusion.

  Supports both standard equi-join blocking keys and LSH bucket keys.
  When lsh_table is provided, LSH bucket columns are joined from that table.

  Parameters:
    target_table: fully-qualified output table for candidate pairs
    source_table: fully-qualified featured source table
    canonical_table: fully-qualified gold canonical table (for cross-batch)
    blocking_paths: list of {keys, lsh_keys, candidate_limit, index}
    cross_batch: bool — whether to compare against gold canonicals
    excluded_pairs_table: table of already-matched pairs from prior tiers (or None)
    tier_name: string identifier for this tier
    lsh_table: fully-qualified LSH bucket table (or None if no LSH paths)
#}

CREATE OR REPLACE TABLE `{{ target_table }}`
{% if cluster_by %}
CLUSTER BY {{ cluster_by | join(', ') }}
{% endif %}
AS

WITH

{% if lsh_table %}
{# Pre-join source data with LSH buckets for paths that need them #}
source_with_lsh AS (
  SELECT
    s.*,
    lsh.* EXCEPT(entity_uid)
  FROM `{{ source_table }}` s
  LEFT JOIN `{{ lsh_table }}` lsh USING (entity_uid)
),
{% endif %}

{# --- Intra-batch candidate pairs (new records vs new records) --- #}
{% for path in blocking_paths %}
intra_path_{{ path.index }} AS (
  SELECT
    l.entity_uid AS l_entity_uid,
    r.entity_uid AS r_entity_uid,
    '{{ tier_name }}_intra_{{ path.index }}' AS blocking_path
  {% if path.lsh_keys and lsh_table %}
  FROM source_with_lsh l
  INNER JOIN source_with_lsh r
  {% else %}
  FROM `{{ source_table }}` l
  INNER JOIN `{{ source_table }}` r
  {% endif %}
    ON l.entity_uid < r.entity_uid
    {% if link_type is defined and link_type == 'dedupe_only' %}
    AND l.source_name = r.source_name
    {% elif link_type is defined and link_type == 'link_only' %}
    AND l.source_name != r.source_name
    {% endif %}
    {% for key in path['keys'] %}
    AND l.{{ key }} = r.{{ key }}
    AND l.{{ key }} IS NOT NULL
    {% endfor %}
    {% for key in path.lsh_keys %}
    AND l.{{ key }} = r.{{ key }}
    AND l.{{ key }} IS NOT NULL
    {% endfor %}
  {% if path.candidate_limit > 0 %}
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY l.entity_uid
    ORDER BY r.entity_uid
  ) <= {{ path.candidate_limit }}
  {% endif %}
),
{% endfor %}

{# --- Cross-batch candidate pairs (new records vs gold canonicals) --- #}
{% if cross_batch %}
{% if lsh_table %}
{# Pre-join canonical data with LSH buckets #}
canonical_with_lsh AS (
  SELECT
    c.*,
    lsh.* EXCEPT(entity_uid)
  FROM `{{ canonical_table }}` c
  LEFT JOIN `{{ lsh_table }}` lsh USING (entity_uid)
),
{% endif %}
{% for path in blocking_paths %}
cross_path_{{ path.index }} AS (
  SELECT
    l.entity_uid AS l_entity_uid,
    r.entity_uid AS r_entity_uid,
    '{{ tier_name }}_cross_{{ path.index }}' AS blocking_path
  {% if path.lsh_keys and lsh_table %}
  FROM source_with_lsh l
  INNER JOIN canonical_with_lsh r
  {% else %}
  FROM `{{ source_table }}` l
  INNER JOIN `{{ canonical_table }}` r
  {% endif %}
    ON l.entity_uid != r.entity_uid
    {% if link_type is defined and link_type == 'dedupe_only' %}
    AND l.source_name = r.source_name
    {% elif link_type is defined and link_type == 'link_only' %}
    AND l.source_name != r.source_name
    {% endif %}
    {% for key in path['keys'] %}
    AND l.{{ key }} = r.{{ key }}
    AND l.{{ key }} IS NOT NULL
    {% endfor %}
    {% for key in path.lsh_keys %}
    AND l.{{ key }} = r.{{ key }}
    AND l.{{ key }} IS NOT NULL
    {% endfor %}
  {% if path.candidate_limit > 0 %}
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY l.entity_uid
    ORDER BY r.entity_uid
  ) <= {{ path.candidate_limit }}
  {% endif %}
),
{% endfor %}
{% endif %}

{# --- Union all paths --- #}
all_candidates AS (
  {% for path in blocking_paths %}
  SELECT l_entity_uid, r_entity_uid, blocking_path FROM intra_path_{{ path.index }}
  UNION ALL
  {% endfor %}
  {% if cross_batch %}
  {% for path in blocking_paths %}
  SELECT l_entity_uid, r_entity_uid, blocking_path FROM cross_path_{{ path.index }}
  {{ "UNION ALL" if not loop.last else "" }}
  {% endfor %}
  {% else %}
  {# Remove trailing UNION ALL from intra-only #}
  SELECT CAST(NULL AS STRING), CAST(NULL AS STRING), CAST(NULL AS STRING)
  WHERE FALSE
  {% endif %}
),

{# Deduplicate: same pair from multiple paths should appear once #}
deduplicated AS (
  SELECT DISTINCT
    l_entity_uid,
    r_entity_uid
  FROM all_candidates
  WHERE l_entity_uid IS NOT NULL
)

{# Exclude pairs already matched in prior tiers #}
SELECT d.l_entity_uid, d.r_entity_uid
FROM deduplicated d
{% if excluded_pairs_table %}
LEFT JOIN `{{ excluded_pairs_table }}` e
  ON (d.l_entity_uid = e.l_entity_uid AND d.r_entity_uid = e.r_entity_uid)
  OR (d.l_entity_uid = e.r_entity_uid AND d.r_entity_uid = e.l_entity_uid)
WHERE e.l_entity_uid IS NULL
{% endif %}

{#
  Estimate m/u probabilities from labeled training pairs.

  The labeled_pairs_table must have columns:
    l_entity_uid STRING — left entity identifier
    r_entity_uid STRING — right entity identifier
    is_match BOOL       — TRUE for confirmed match, FALSE for confirmed non-match

  For each comparison and each level, computes:
    m = P(level outcome | is_match = TRUE)
    u = P(level outcome | is_match = FALSE)

  Parameters:
    labeled_pairs_table: fully-qualified BigQuery table of labeled pairs
    source_table: fully-qualified featured source table
    comparisons: list of {name, left, right, levels: [{label, sql_expr, has_expr}]}
#}

{% for comp in comparisons %}
{% for level in comp.levels %}
{% if level.has_expr %}
SELECT
  '{{ comp.name }}' AS comparison_name,
  '{{ level.label }}' AS level_label,
  SAFE_DIVIDE(
    COUNTIF(lp.is_match AND ({{ level.sql_expr }})),
    NULLIF(COUNTIF(lp.is_match), 0)
  ) AS m_probability,
  SAFE_DIVIDE(
    COUNTIF(NOT lp.is_match AND ({{ level.sql_expr }})),
    NULLIF(COUNTIF(NOT lp.is_match), 0)
  ) AS u_probability,
  SAFE_DIVIDE(COUNTIF(lp.is_match), COUNT(*)) AS match_rate
FROM `{{ labeled_pairs_table }}` lp
INNER JOIN `{{ source_table }}` l ON lp.l_entity_uid = l.entity_uid
INNER JOIN `{{ source_table }}` r ON lp.r_entity_uid = r.entity_uid
{% if not loop.last or not loop.parent.last %}
UNION ALL
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}

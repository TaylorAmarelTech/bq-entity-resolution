{#
  Generate active learning review queue.

  Selects pairs nearest to the decision boundary for human review.
  For Fellegi-Sunter: pairs where match_confidence is closest to 0.5.
  For sum scoring: pairs where total_score is closest to threshold.

  Parameters:
    review_table: fully-qualified output table for review queue
    matches_table: fully-qualified matches table (has scored pairs)
    candidates_table: fully-qualified candidates table
    source_table: fully-qualified featured source table
    queue_size: int — number of pairs to surface
    threshold: {method, min_score, match_threshold}
    uncertainty_window: float — range around decision boundary
    is_fellegi_sunter: bool
#}

CREATE OR REPLACE TABLE `{{ review_table }}` AS

{% if is_fellegi_sunter %}
{#
  For Fellegi-Sunter: uncertainty = distance from 0.5 match probability.
  We look at the matches table which contains pairs above the match threshold,
  but we also want pairs just below it — so we query from candidates and re-score.
  Since re-scoring is expensive, we use the matches table and look for low-confidence matches.
#}
SELECT
  l_entity_uid,
  r_entity_uid,
  total_score,
  match_confidence,
  ABS(match_confidence - 0.5) AS uncertainty,
  CAST(NULL AS BOOL) AS human_label,
  CURRENT_TIMESTAMP() AS queued_at
FROM `{{ matches_table }}`
WHERE ABS(match_confidence - 0.5) <= {{ uncertainty_window }}
ORDER BY ABS(match_confidence - 0.5) ASC
LIMIT {{ queue_size }}

{% else %}
{#
  For sum-based scoring: uncertainty = distance from threshold.
  Look for pairs near the decision boundary.
#}
SELECT
  l_entity_uid,
  r_entity_uid,
  total_score,
  match_confidence,
  {% if threshold.min_score > 0 %}
  ABS(total_score - {{ threshold.min_score }}) AS uncertainty,
  {% else %}
  ABS(match_confidence - 0.5) AS uncertainty,
  {% endif %}
  CAST(NULL AS BOOL) AS human_label,
  CURRENT_TIMESTAMP() AS queued_at
FROM `{{ matches_table }}`
{% if threshold.min_score > 0 %}
ORDER BY ABS(total_score - {{ threshold.min_score }}) ASC
{% else %}
ORDER BY ABS(match_confidence - 0.5) ASC
{% endif %}
LIMIT {{ queue_size }}

{% endif %}

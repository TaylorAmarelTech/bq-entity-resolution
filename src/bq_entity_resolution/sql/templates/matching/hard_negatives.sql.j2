{#
  Hard negative SQL expression generators.
  These are included in tier_comparisons.sql.j2 via the hard_negatives parameter.
  This file documents the available hard negative patterns for reference.

  Hard negative types and their SQL patterns:

  "different" — values differ (both non-null)
    (l.{col} != r.{col} AND l.{col} IS NOT NULL AND r.{col} IS NOT NULL)

  "null_either" — either value is null
    (l.{col} IS NULL OR r.{col} IS NULL)

  "length_mismatch" — string lengths differ by more than threshold
    (ABS(CHAR_LENGTH(l.{col}) - CHAR_LENGTH(r.{col})) > {threshold})

  "suffix_mismatch" — detected suffixes differ (Jr vs Sr, II vs III)
    (l.{col} != r.{col} AND l.{col} IS NOT NULL AND r.{col} IS NOT NULL)

  "entity_type_mismatch" — different entity type classifications
    (l.{col} != r.{col})

  "custom" — raw SQL condition provided via the `sql` field
    ({sql})
#}

{# This template is documentation-only. Hard negative SQL expressions are
   generated by Python (matching/hard_negatives.py) and passed as parameters
   to tier_comparisons.sql.j2. #}

{#
  Populate the canonical_index table after clustering.

  Updates cluster_ids for prior entities that were re-clustered, and
  inserts new entities from the current batch.

  Parameters:
    canonical_table: fully-qualified canonical index table
    source_table: fully-qualified featured source table (current batch)
    cluster_table: fully-qualified cluster assignment table
#}

-- Update cluster_ids for prior entities that were re-clustered
UPDATE `{{ canonical_table }}` ci
SET cluster_id = cl.cluster_id
FROM `{{ cluster_table }}` cl
WHERE ci.entity_uid = cl.entity_uid
  AND ci.cluster_id != cl.cluster_id;

-- Insert new entities from current batch
INSERT INTO `{{ canonical_table }}`
SELECT f.*, cl.cluster_id
FROM `{{ source_table }}` f
JOIN `{{ cluster_table }}` cl USING (entity_uid)
WHERE f.entity_uid NOT IN (SELECT entity_uid FROM `{{ canonical_table }}`);

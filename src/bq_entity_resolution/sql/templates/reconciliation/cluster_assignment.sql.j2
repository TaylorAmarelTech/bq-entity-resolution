{#
  Assign entity clusters using connected components via iterative BQ scripting.

  Propagates the minimum entity_uid as cluster_id through match edges until
  convergence (no more changes) or max iterations is reached.

  ALL source entities are initialized in the cluster table — unmatched
  entities remain as singleton clusters in the gold output.

  Parameters:
    all_matches_table: fully-qualified table with all tier matches
    cluster_table: fully-qualified output table for cluster assignments
    source_table: fully-qualified featured source table (all entities)
    max_iterations: safety limit for convergence loop
#}

DECLARE iteration INT64 DEFAULT 0;
DECLARE rows_updated INT64 DEFAULT 1;

-- Step 1: Initialize ALL entities as their own cluster (singletons).
-- This ensures unmatched entities appear in the gold output.
CREATE OR REPLACE TABLE `{{ cluster_table }}` AS
SELECT DISTINCT entity_uid, entity_uid AS cluster_id
FROM `{{ source_table }}`;

-- Step 2: Iteratively propagate minimum cluster_id through match edges
WHILE rows_updated > 0 AND iteration < {{ max_iterations }} DO

  -- Build edge list with current cluster assignments
  CREATE OR REPLACE TEMP TABLE _edge_clusters AS
  SELECT
    c1.entity_uid AS uid1,
    c1.cluster_id AS cid1,
    c2.entity_uid AS uid2,
    c2.cluster_id AS cid2
  FROM `{{ all_matches_table }}` m
  JOIN `{{ cluster_table }}` c1 ON m.l_entity_uid = c1.entity_uid
  JOIN `{{ cluster_table }}` c2 ON m.r_entity_uid = c2.entity_uid;

  -- Compute new cluster_id = minimum reachable cluster_id
  CREATE OR REPLACE TEMP TABLE _new_clusters AS
  SELECT
    entity_uid,
    LEAST(
      cluster_id,
      COALESCE(min_neighbor, cluster_id)
    ) AS cluster_id
  FROM (
    SELECT
      c.entity_uid,
      c.cluster_id,
      MIN(
        LEAST(
          COALESCE(e.cid1, c.cluster_id),
          COALESCE(e.cid2, c.cluster_id)
        )
      ) AS min_neighbor
    FROM `{{ cluster_table }}` c
    LEFT JOIN _edge_clusters e
      ON c.entity_uid = e.uid1 OR c.entity_uid = e.uid2
    GROUP BY c.entity_uid, c.cluster_id
  );

  -- Count how many changed
  SET rows_updated = (
    SELECT COUNT(*)
    FROM _new_clusters n
    JOIN `{{ cluster_table }}` o USING (entity_uid)
    WHERE n.cluster_id != o.cluster_id
  );

  -- Replace cluster table
  CREATE OR REPLACE TABLE `{{ cluster_table }}` AS
  SELECT * FROM _new_clusters;

  SET iteration = iteration + 1;

END WHILE;

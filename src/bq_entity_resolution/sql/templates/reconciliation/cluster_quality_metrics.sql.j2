{#
  Compute cluster quality metrics after connected components assignment.

  Monitors cluster health to detect over-merging (false positives
  propagating through transitivity) and assess resolution quality.

  Parameters:
    cluster_table: fully-qualified entity clusters table
    matches_table: fully-qualified all matches table
#}

WITH cluster_stats AS (
  SELECT
    cluster_id,
    COUNT(*) AS cluster_size,
    COUNT(DISTINCT source_name) AS source_count
  FROM `{{ cluster_table }}`
  GROUP BY cluster_id
),
confidence_stats AS (
  SELECT
    AVG(match_confidence) AS avg_match_confidence,
    MIN(match_confidence) AS min_match_confidence
  FROM `{{ matches_table }}`
)
SELECT
  COUNT(*) AS cluster_count,
  SUM(CASE WHEN cluster_size = 1 THEN 1 ELSE 0 END) AS singleton_count,
  SAFE_DIVIDE(
    SUM(CASE WHEN cluster_size = 1 THEN 1 ELSE 0 END),
    COUNT(*)
  ) AS singleton_ratio,
  MAX(cluster_size) AS max_cluster_size,
  AVG(cluster_size) AS avg_cluster_size,
  APPROX_QUANTILES(cluster_size, 2)[OFFSET(1)] AS median_cluster_size,
  AVG(source_count) AS avg_source_diversity,
  cs.avg_match_confidence,
  cs.min_match_confidence,
  CURRENT_TIMESTAMP() AS computed_at
FROM cluster_stats
CROSS JOIN confidence_stats cs
GROUP BY cs.avg_match_confidence, cs.min_match_confidence
